{
  "manifest_version": 3,
  "name": "ChatGPT Branch Map",
  "version": "0.1.0",
  "description": "为 ChatGPT 对话提供分支节点、树状导航与回溯定位能力。",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
